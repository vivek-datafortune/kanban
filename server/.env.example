# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-real-key-before-use

DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated; use * to allow all in development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Frontend URL (used in invitation emails) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (matches the db service in docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@db:5432/trello

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for Channels (WebSocket layer) and Django cache
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed React dev origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Email ─────────────────────────────────────────────────────────────────────
# Use console backend during development (prints emails to stdout)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ── allauth ───────────────────────────────────────────────────────────────────
# 'none' | 'optional' | 'mandatory'
ACCOUNT_EMAIL_VERIFICATION=none

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
# Register at https://portal.azure.com → App registrations → New registration
# Redirect URI: http://localhost:5173/auth/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ── Google OAuth ────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:5173/auth/callback?provider=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Postgres container credentials (used by docker-compose) ───────────────────
POSTGRES_DB=trello
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
